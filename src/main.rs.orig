mod projectile_plugin;
use crate::projectile_plugin::*;
use bevy::diagnostic::{DiagnosticsStore, FrameTimeDiagnosticsPlugin};
use bevy::math::bounding::{Aabb2d, IntersectsVolume};
use bevy::math::*;
